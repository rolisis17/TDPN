{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gpm.local/schemas/gpm-bootstrap-manifest-v1.schema.json",
  "title": "GPM Bootstrap Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at_utc",
    "expires_at_utc",
    "bootstrap_directories"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at_utc": {
      "type": "string",
      "format": "date-time",
      "description": "Must be after generated_at_utc and no more than 24 hours after generated_at_utc."
    },
    "bootstrap_directories": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "string",
        "format": "uri",
        "maxLength": 240
      },
      "uniqueItems": true
    },
    "gateway_mirrors": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "$ref": "#/$defs/url_hint"
      }
    },
    "bootstrap_sources": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/url_hint"
      }
    },
    "relay_hints": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/relay_hint"
      }
    },
    "bridge_hints": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/bridge_hint"
      }
    },
    "relay_policy": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "operator_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "url_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "kind"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "maxLength": 240
        },
        "kind": {
          "type": "string",
          "enum": ["official", "mirror", "dns-seed", "directory-seed", "offline-bundle"]
        },
        "operator_id": {
          "$ref": "#/$defs/operator_id"
        },
        "key_id": {
          "$ref": "#/$defs/id"
        },
        "expires_at_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "relay_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relay_id", "operator_id", "hint_source"],
      "properties": {
        "relay_id": {
          "$ref": "#/$defs/id"
        },
        "operator_id": {
          "$ref": "#/$defs/operator_id"
        },
        "directory_url": {
          "type": "string",
          "format": "uri",
          "maxLength": 240
        },
        "entry_url": {
          "type": "string",
          "format": "uri",
          "maxLength": 240
        },
        "public_host": {
          "type": "string",
          "maxLength": 180
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "region": {
          "type": "string",
          "maxLength": 80
        },
        "hint_source": {
          "type": "string",
          "enum": ["signed-manifest", "directory", "dns-seed", "bridge"]
        },
        "expires_at_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "bridge_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bridge_id", "endpoint", "transport", "ticket_required"],
      "properties": {
        "bridge_id": {
          "$ref": "#/$defs/id"
        },
        "operator_id": {
          "$ref": "#/$defs/operator_id"
        },
        "endpoint": {
          "type": "string",
          "format": "uri",
          "maxLength": 240
        },
        "transport": {
          "type": "string",
          "enum": ["https", "quic", "obfs-https", "offline"]
        },
        "ticket_required": {
          "type": "boolean"
        },
        "rate_limit_class": {
          "type": "string",
          "enum": ["low", "standard", "event", "support"]
        },
        "expires_at_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
