{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gpm.local/schemas/access-recovery-bridge-invite-v0.schema.json",
  "title": "Access Recovery Bridge Invite v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "invite_id",
    "organization",
    "issued_at_utc",
    "expires_at_utc",
    "intended_audience",
    "helper",
    "access_paths"
  ],
  "properties": {
    "schema_version": {
      "const": 0
    },
    "invite_id": {
      "type": "string",
      "pattern": "^bri-[a-zA-Z0-9_-]{8,96}$"
    },
    "organization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["org_id", "name"],
      "properties": {
        "org_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "home_url": {
          "type": "string",
          "format": "uri",
          "maxLength": 240
        }
      }
    },
    "issued_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "intended_audience": {
      "type": "string",
      "maxLength": 240
    },
    "helper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["helper_id", "display_name"],
      "properties": {
        "helper_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
        },
        "display_name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "contact_url": {
          "type": "string",
          "format": "uri",
          "maxLength": 240
        },
        "description": {
          "type": "string",
          "maxLength": 180
        }
      }
    },
    "access_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "$ref": "access-recovery-pack-v0.schema.json#/$defs/access_path"
      }
    },
    "safety_notes": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "maxLength": 240
      }
    },
    "signature": {
      "$ref": "access-recovery-pack-v0.schema.json#/$defs/signature"
    }
  }
}
