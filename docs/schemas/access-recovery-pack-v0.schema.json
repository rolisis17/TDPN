{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gpm.local/schemas/access-recovery-pack-v0.schema.json",
  "title": "Access Recovery Pack v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "organization",
    "issued_at_utc",
    "expires_at_utc",
    "intended_audience",
    "sources",
    "access_paths"
  ],
  "properties": {
    "schema_version": {
      "const": 0
    },
    "pack_id": {
      "type": "string",
      "pattern": "^arp-[a-zA-Z0-9_-]{8,96}$"
    },
    "organization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["org_id", "name"],
      "properties": {
        "org_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "home_url": {
          "type": "string",
          "format": "uri",
          "maxLength": 240
        }
      }
    },
    "issued_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "intended_audience": {
      "type": "string",
      "maxLength": 240
    },
    "sources": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "access_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/access_path"
      }
    },
    "safety_notes": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "maxLength": 240
      }
    },
    "signature": {
      "$ref": "#/$defs/signature"
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "kind", "url"],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
        },
        "kind": {
          "type": "string",
          "enum": ["official", "mirror", "cache", "bridge", "offline-bundle"]
        },
        "url": {
          "type": "string",
          "format": "uri",
          "maxLength": 240
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "description": {
          "type": "string",
          "maxLength": 160
        }
      }
    },
    "access_path": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_id", "kind", "url"],
      "properties": {
        "path_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
        },
        "kind": {
          "type": "string",
          "enum": ["website", "mirror", "api", "bridge", "tor-onion", "outline", "shadowsocks", "gpm", "instructions"]
        },
        "url": {
          "type": "string",
          "format": "uri",
          "maxLength": 512
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "requires_external_app": {
          "type": "boolean"
        },
        "launch_hint": {
          "type": "string",
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "maxLength": 180
        },
        "safety_notes": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "maxLength": 180
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "key_id", "sig"],
      "properties": {
        "alg": {
          "type": "string",
          "enum": ["ed25519"]
        },
        "key_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 160
        },
        "sig": {
          "type": "string",
          "minLength": 32,
          "maxLength": 256
        }
      }
    }
  }
}
